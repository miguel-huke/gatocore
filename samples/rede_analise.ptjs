definir pacote_tcp como pacote(new Uint8Array([
  0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff,
  0x11, 0x22, 0x33, 0x44, 0x55, 0x66,
  0x08, 0x00,
  0x45, 0x00, 0x00, 0x28, 0x00, 0x01, 0x00, 0x00,
  0x40, 0x06, 0x00, 0x00,
  10, 0, 0, 1,
