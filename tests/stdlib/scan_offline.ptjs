definir scan como varrer_arquivo("../runtime/parte_include.inc")
mostrar scan.ok
mostrar scan.valor.tipo_arquivo
mostrar scan.valor.tamanho_bytes > 0

definir cabecalho_pcap como new Uint8Array([
  0xd4, 0xc3, 0xb2, 0xa1,
  0x02, 0x00,
  0x04, 0x00,
  0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00,
  0xff, 0xff, 0x00, 0x00,
  0x01, 0x00, 0x00, 0x00
]).buffer
mostrar pcap(cabecalho_pcap).formato

definir cabecalho_pcapng como new Uint8Array([
  0x0a, 0x0d, 0x0d, 0x0a,
  0x1c, 0x00, 0x00, 0x00,
  0x4d, 0x3c, 0x2b, 0x1a,
  0x00, 0x00, 0x00, 0x00
]).buffer
mostrar pcapng(cabecalho_pcapng).formato
